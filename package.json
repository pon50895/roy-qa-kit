{
  "name": "e2e-qa-framework",
  "version": "0.1.0",
  "private": true,
  "description": "通用 E2E/QA 框架（Playwright Test）— 方法+分類+矩陣+多環境+報告",
  "scripts": {
    "init": "node scripts/init.mjs",
    "login": "node scripts/login.example.mjs",
    "test": "playwright test",
    "test:mock": "playwright test --grep @mock",
    "test:smoke": "playwright test --grep @smoke",
    "test:p0": "playwright test --grep @p0",
    "test:uat": "ENV=uat playwright test",
    "test:prod": "ENV=prod playwright test",
    "export": "node helpers/export-results.mjs && python3 helpers/results_to_xlsx.py",
    "report": "playwright show-report",
    "scan": "node scripts/scan.mjs",
    "precommit": "node scripts/scan.mjs",
    "security": "node scripts/security-scan.mjs",
    "test:security": "playwright test --grep @security",
    "test:perf": "playwright test --grep @perf",
    "perf:load": "k6 run perf/load-test.example.js",
    "metrics": "node scripts/metrics.mjs",
    "health": "node scripts/health-check.mjs",
    "pretest": "node scripts/health-check.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "dotenv": "^16.4.5"
  }
}